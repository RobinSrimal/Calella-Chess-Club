---
import { Resource } from "sst/resource/cloudflare";
import PublicLayout from "../../layouts/PublicLayout.astro";
import PageIntro from "../../components/PageIntro.astro";
import { getTranslations } from "../../i18n";
import { verifyEmailToken } from "../../lib/email-verification";
import { getLocaleFromParam, writeLocaleCookie } from "../../lib/locale";

const locale = getLocaleFromParam(Astro.params.locale);
if (!locale) {
  return Astro.redirect("/ca");
}

writeLocaleCookie(Astro.cookies, locale);
const t = getTranslations(locale);
const verification = await verifyEmailToken({
  token: Astro.url.searchParams.get("token"),
  auth: Resource.AuthApi,
});

const errorMessages: Record<string, string> = {
  AUTH_VERIFICATION_TOKEN_INVALID: "This verification link is invalid.",
  AUTH_VERIFICATION_TOKEN_USED: "This verification link has already been used.",
  AUTH_VERIFICATION_TOKEN_EXPIRED: "This verification link has expired.",
  AUTH_VERIFICATION_FAILED: "Could not verify this email address.",
};

function errorMessageFor(code: string) {
  return errorMessages[code] ?? "Could not verify this email address.";
}
---

<PublicLayout locale={locale} title={t.auth.verifyTitle} currentPath={Astro.url.pathname}>
  <PageIntro title={t.auth.verifyTitle} />
  <div class="shell-inner content-stack">
    {
      verification.status === "verified" ? (
        <section class="panel" aria-live="polite">
          <p class="form-message success">{t.auth.verifySuccess}</p>
          <p>{t.auth.verifyPending}</p>
          <div class="actions">
            <a class="button-link" href={`/${locale}/login`}>
              {t.nav.login}
            </a>
          </div>
        </section>
      ) : verification.status === "missing-token" ? (
        <section class="panel">
          <p class="form-message error" role="alert">
            This verification link is invalid.
          </p>
        </section>
      ) : (
        <section class="panel">
          <p class="form-message error" role="alert">
            {errorMessageFor(verification.code)}
          </p>
        </section>
      )
    }
  </div>
</PublicLayout>
